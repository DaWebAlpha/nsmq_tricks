<%- include("../../partials/header", { title: "register" }) %>
<%- include("../../partials/sub_nav") %>

<main role="main">
    <section class="section__form">
        <div class="form__container">
            <div class="form__card">
                <header class="form__header">
                    <div class="logo__icon">⚡</div>
                    <h2 id="registerHeading">Sign Up</h2>
                    <p>Register an account</p>
                </header>

                <% if (success) { %>
                    <div class="alert success__alert centered">
                        <%= success %>
                    </div>
                <% } %>

                <% if (error) { %>
                    <div class="alert error__alert centered">
                        <%= error %>
                    </div>
                <% } %>

                <form
                    action="/auth/page/register"
                    method="POST"
                    role="form"
                    novalidate
                    autocomplete="off"
                    aria-labelledby="registerHeading"
                    class="form"
                    id="registerForm"
                >
                    <input
                        type="hidden"
                        name="_csrf"
                        value="<%= csrfToken || '' %>"
                    />

                    <div class="form__group">
                        <div class="input__wrapper">
                            <label for="username" class="form__label">
                                Username:
                            </label>
                            <input
                                type="text"
                                name="username"
                                class="form__control input"
                                id="username"
                                placeholder="Enter username"
                                aria-describedby="usernameError"
                                autocomplete="username"
                                value="<%= oldInput?.username || '' %>"
                                required
                            />
                            <span class="input__line"></span>
                            <small class="form__error" id="usernameError"></small>
                        </div>
                    </div>

                    <div class="form__group">
                        <div class="input__wrapper">
                            <label for="email" class="form__label">
                                Email:
                            </label>
                            <input
                                type="email"
                                name="email"
                                class="form__control input"
                                id="email"
                                placeholder="Enter email"
                                aria-describedby="emailError"
                                autocomplete="email"
                                value="<%= oldInput?.email || '' %>"
                                required
                            />
                            <span class="input__line"></span>
                            <small class="form__error" id="emailError"></small>
                        </div>
                    </div>

                    <div class="form__group">
                        <div class="input__wrapper">
                            <label for="phoneNumber" class="form__label">
                                Phone Number:
                            </label>
                            <input
                                type="text"
                                name="phoneNumber"
                                class="form__control input"
                                id="phoneNumber"
                                placeholder="Enter phone number"
                                aria-describedby="phoneNumberError"
                                autocomplete="tel"
                                value="<%= oldInput?.phoneNumber || '' %>"
                                required
                            />
                            <span class="input__line"></span>
                            <small class="form__error" id="phoneNumberError"></small>
                        </div>
                    </div>

                    <div class="form__group">
                        <div class="input__wrapper password__wrapper">
                            <label for="password" class="form__label">
                                Password:
                            </label>
                            <input
                                type="password"
                                name="password"
                                class="form__control input"
                                id="password"
                                placeholder="Enter password"
                                aria-describedby="passwordError"
                                autocomplete="new-password"
                                required
                            />
                            <button
                                type="button"
                                class="password__toggle"
                                id="passwordToggle"
                                aria-label="Toggle password visibility"
                            >
                                <span class="toggle__icon"></span>
                            </button>
                            <span class="input__line"></span>
                            <small class="form__error" id="passwordError"></small>
                        </div>
                    </div>

                    <button type="submit" class="login__button btn">
                        <span class="button__text">Create Account</span>
                        <span class="button__loader"></span>
                        <span class="button__glow"></span>
                    </button>
                </form>

                <div class="divider">
                    <span>or</span>
                </div>

                <div class="signup__link">
                    <p>Already have an account? <a href="/auth/page/login">Login</a></p>
                </div>
            </div>
        </div>
    </section>
</main>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const alerts = document.querySelectorAll(
            ".success__alert, .error__alert"
        );

        if (!alerts.length) return;

        setTimeout(() => {
            alerts.forEach((item) => {
                item.remove();
            });
        }, 5000);
    });
</script>

<%- include("../../partials/register_footer") %>
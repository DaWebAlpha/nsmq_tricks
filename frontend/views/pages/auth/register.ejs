<%- include("../../partials/sub_nav") %>

<main role="main">
    <section>
        <!-- ========================================================= -->
        <!-- PAGE HEADER -->
        <!-- ========================================================= -->
        <header class="centered">
            Sign Up
        </header>

        <!-- ========================================================= -->
        <!-- FLASH MESSAGES (OPTIONAL) -->
        <!-- ========================================================= -->

        <% if(success) { %>
            <div class="alert success-alert">
                <%= success %>
            </div>
        <% } %>

        <% if(error){ %>
            <div class="alert error__alert">
                <%= error %>
            </div>
        <% } %>


        <!-- ================================================= -->
        <!-- LOGIN FORM-->
        <!-- ================================================= -->
        <form
            action="/auth/page/register"
            method="POST"
            role="form"
            novalidate
            autocomplete="off"
            aria-labelledby="registerHeading"
            class="form"
        >
            <div class="form__group">
                <label 
                    for="username"
                    class="form__label"
                >
                    Username:
                </label>
                <input
                    type="text"
                    id="username"
                    class="form__control input"
                    placeholder="Enter Username"
                    aria-describedby="usernameHelp"
                    autocomplete="username"
                    required
                />
            </div>

            <div
                class="form__group"
            >
                <label
                    for="email"
                    class="form__label"
                >
                    Email:
                </label>
                <input 
                    type="email"
                    id="email"
                    class="form__control input"
                    placeholder="Enter Email"
                    aria-describedby="emailHelp"
                    autocomplete="email"
                    required
                />
            </div>

            <div class="form__control">
                <label
                    for="phoneNumber"
                    class="form__label"
                >
                    PhoneNumber:
                </label>
                <input
                    type="number"
                    id="phoneNumber"
                    class="form__control input"
                    placeholder="Enter Phonenumber"
                    aria-describedby="phoneNumberHelp"
                    autocomplete="phoneNumber"
                    required

                />

            </div>
            <div class="form__group">
                <button
                    type="submit"
                    class="button success__button button__block"
                >
                    Register
                </button>
            </div>
            <div class="form__group centered">
                <a href="/auth/page/login" class="nav__link">
                        Already registered? Login
                </a>
            </div>
        </form>
    </section>
</main>

<%- include("../../partials/sub_nav") %>
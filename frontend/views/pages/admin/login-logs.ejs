<%- include("../../partials/header", {title: "Login Logs"}) %>
<%- include("../../partials/navigation_nav", {
    nav1: "/admin/login-logs",
    title1: "Login Logs",
    nav2: "/admin/home",
    title2: "Go back home"
}) %>

<main role="main" class="admin__main">
    <section class="admin__hero">
        <div class="container">
            <div class="admin__hero-card">
                <p class="admin__eyebrow">Authentication Logs</p>
                <h1 class="admin__title">Login Logs</h1>
                <p class="admin__text">
                    Review successful login attempts, devices, IP addresses, and timestamps.
                </p>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="container">
            <article class="admin__panel">
                <header class="admin__panel-header">
                    <div>
                        <p class="admin__eyebrow">Logs</p>
                        <h2>Successful Logins</h2>
                    </div>
                </header>

                <% if (typeof logs !== "undefined" && logs?.length) { %>
                    <div class="table-wrapper">
                        <table class="table">
                            <thead class="table__header">
                                <tr class="table__row">
                                    <th class="table__cell">User</th>
                                    <th class="table__cell">IP Address</th>
                                    <th class="table__cell">Device</th>
                                    <th class="table__cell">User Agent</th>
                                    <th class="table__cell">Date</th>
                                </tr>
                            </thead>
                            <tbody class="table__body">
                                <% logs.forEach((log) => { %>
                                    <tr class="table__row">
                                        <td class="table__cell"><%= log?.user?.username ?? log?.userId ?? "N/A" %></td>
                                        <td class="table__cell"><%= log?.ipAddress ?? "N/A" %></td>
                                        <td class="table__cell"><%= log?.deviceName ?? "N/A" %></td>
                                        <td class="table__cell"><%= log?.userAgent ?? "N/A" %></td>
                                        <td class="table__cell"><%= log?.createdAt ? new Date(log.createdAt).toLocaleString() : "N/A" %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="alert info__alert">No login logs available yet.</div>
                <% } %>
            </article>
        </div>
    </section>
</main>

<%- include("../../partials/admin_footer") %>
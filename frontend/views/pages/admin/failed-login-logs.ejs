<%- include("../../partials/header", {title: "Failed Login Logs"}) %>
<%- include("../../partials/navigation_nav", {
    nav1: "/admin/failed-login-logs",
    title1: "Failed Logs",
    nav2: "/admin/home",
    title2: "Go back home"
}) %>

<main role="main" class="admin__main">
    <section class="admin__hero">
        <div class="container">
            <div class="admin__hero-card">
                <p class="admin__eyebrow">Security Monitoring</p>
                <h1 class="admin__title">Failed Login Logs</h1>
                <p class="admin__text">
                    Track failed login attempts, suspicious devices, IP addresses, and reasons.
                </p>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="container">
            <article class="admin__panel">
                <header class="admin__panel-header">
                    <div>
                        <p class="admin__eyebrow">Failed Attempts</p>
                        <h2>Authentication Failures</h2>
                    </div>
                </header>

                <% if (failedLoginLogs?.length) { %>
                    <div class="table-wrapper">
                        <table class="table">
                            <thead class="table__header">
                                <tr class="table__row">
                                    <th class="table__cell">Identifier</th>
                                    <th class="table__cell">Reason</th>
                                    <th class="table__cell">IP Address</th>
                                    <th class="table__cell">Device</th>
                                    <th class="table__cell">User Agent</th>
                                    <th class="table__cell">Attempted At</th>
                                </tr>
                            </thead>

                            <tbody class="table__body">
                                <% failedLoginLogs.forEach((log) => { %>
                                    <tr class="table__row">
                                        <td class="table__cell"><%= log?.identifier ?? "N/A" %></td>
                                        <td class="table__cell">
                                            <span class="badge error__badge">
                                                <%= log?.reason ?? "unknown" %>
                                            </span>
                                        </td>
                                        <td class="table__cell"><%= log?.ipAddress ?? "N/A" %></td>
                                        <td class="table__cell"><%= log?.deviceName ?? log?.deviceId ?? "N/A" %></td>
                                        <td class="table__cell"><%= log?.userAgent ?? "N/A" %></td>
                                        <td class="table__cell">
                                            <%= log?.attemptedAt
                                                ? new Date(log.attemptedAt).toLocaleString()
                                                : log?.createdAt
                                                    ? new Date(log.createdAt).toLocaleString()
                                                    : "N/A"
                                            %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <% if (pagination && pagination.totalPages > 1) { %>
                        <nav class="pagination" aria-label="Failed login logs pagination">
                            <ul class="pagination__list">

                                <% if (pagination.page > 1) { %>
                                    <li class="pagination__item">
                                        <a 
                                            class="pagination__link"
                                            href="/admin/failed-login-logs?page=<%= pagination.page - 1 %>&limit=<%= pagination.limit %>"
                                        >
                                            Prev
                                        </a>
                                    </li>
                                <% } %>

                                <% for (let pageNumber = 1; pageNumber <= pagination.totalPages; pageNumber++) { %>
                                    <li class="pagination__item">
                                        <a 
                                            class="pagination__link <%= Number(pagination.page) === pageNumber ? 'active' : '' %>"
                                            href="/admin/failed-login-logs?page=<%= pageNumber %>&limit=<%= pagination.limit %>"
                                        >
                                            <%= pageNumber %>
                                        </a>
                                    </li>
                                <% } %>

                                <% if (pagination.page < pagination.totalPages) { %>
                                    <li class="pagination__item">
                                        <a 
                                            class="pagination__link"
                                            href="/admin/failed-login-logs?page=<%= pagination.page + 1 %>&limit=<%= pagination.limit %>"
                                        >
                                            Next
                                        </a>
                                    </li>
                                <% } %>

                            </ul>
                        </nav>
                    <% } %>

                <% } else { %>
                    <div class="alert info__alert">
                        No failed login logs available yet.
                    </div>
                <% } %>
            </article>
        </div>
    </section>
</main>

<%- include("../../partials/admin_footer") %>
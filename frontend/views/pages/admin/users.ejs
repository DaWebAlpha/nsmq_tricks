<%- include("../../partials/header", {title: title ?? "Users"}) %>
<%- include("../../partials/navigation_nav", {
    nav1: "/admin/users",
    title1: "Users",
    nav2: "/admin/home",
    title2: "Go back home"
}) %>

<main role="main" class="admin__main">
    <section class="admin__hero">
        <div class="container">
            <div class="admin__hero-card">
                <p class="admin__eyebrow">User Management</p>
                <h1 class="admin__title"><%= title ?? "Manage Users" %></h1>
                <p class="admin__text">
                    View, filter, create, update, delete, restore, and manage user accounts.
                </p>

                <div class="admin__actions">
                    <a href="/admin/users" class="main__button button__text btn">All Users</a>
                    <a href="/admin/users/active" class="main__button button__text btn">Active Users</a>
                    <a href="/admin/users/deleted" class="main__button button__text btn">Deleted Users</a>
                </div>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="container">
            <% if (success) { %>
                <div class="alert success__alert"><%= success %></div>
            <% } %>

            <% if (error) { %>
                <div class="alert error__alert"><%= error %></div>
            <% } %>

            <article class="admin__panel">
                <header class="admin__panel-header">
                    <div>
                        <p class="admin__eyebrow">Create User</p>
                        <h2>Add New User</h2>
                    </div>
                </header>

                <form action="/admin/users" method="POST" class="form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div class="grid__3">
                        <div class="form__group">
                            <label class="form__label" for="username">Username</label>
                            <input class="input" id="username" type="text" name="username" required>
                        </div>

                        <div class="form__group">
                            <label class="form__label" for="email">Email</label>
                            <input class="input" id="email" type="email" name="email" required>
                        </div>

                        <div class="form__group">
                            <label class="form__label" for="phoneNumber">Phone Number</label>
                            <input class="input" id="phoneNumber" type="text" name="phoneNumber" required>
                        </div>

                        <div class="form__group">
                            <label class="form__label" for="password">Password</label>
                            <input class="input" id="password" type="password" name="password" required>
                        </div>

                        <div class="form__group">
                            <label class="form__label" for="role">Role</label>
                            <select class="select" id="role" name="role">
                                <option value="user">User</option>
                                <option value="moderator">Moderator</option>
                                <option value="admin">Admin</option>
                                <option value="superadmin">Super Admin</option>
                            </select>
                        </div>
                    </div>

                    <button type="submit" class="main__button button__text btn">Create User</button>
                </form>
            </article>

            <br>

            <article class="admin__panel">
                <header class="admin__panel-header">
                    <div>
                        <p class="admin__eyebrow">Filters</p>
                        <h2>Search Users</h2>
                    </div>
                </header>

                <form action="<%= typeof currentUrl !== 'undefined' ? currentUrl : '/admin/users' %>" method="GET" class="form">
                    <div class="grid__3">
                        <input class="input" type="text" name="username" placeholder="Username" value="<%= filters?.username ?? '' %>">
                        <input class="input" type="text" name="email" placeholder="Email" value="<%= filters?.email ?? '' %>">
                        <input class="input" type="text" name="phoneNumber" placeholder="Phone" value="<%= filters?.phoneNumber ?? '' %>">

                        <select class="select" name="role">
                            <option value="">All Roles</option>
                            <option value="user" <%= filters?.role === "user" ? "selected" : "" %>>User</option>
                            <option value="moderator" <%= filters?.role === "moderator" ? "selected" : "" %>>Moderator</option>
                            <option value="admin" <%= filters?.role === "admin" ? "selected" : "" %>>Admin</option>
                            <option value="superadmin" <%= filters?.role === "superadmin" ? "selected" : "" %>>Super Admin</option>
                        </select>

                        <select class="select" name="subscriptionPlan">
                            <option value="">All Plans</option>
                            <option value="free" <%= filters?.subscriptionPlan === "free" ? "selected" : "" %>>Free</option>
                            <option value="premium" <%= filters?.subscriptionPlan === "premium" ? "selected" : "" %>>Premium</option>
                            <option value="pro" <%= filters?.subscriptionPlan === "pro" ? "selected" : "" %>>Pro</option>
                            <option value="enterprise" <%= filters?.subscriptionPlan === "enterprise" ? "selected" : "" %>>Enterprise</option>
                        </select>

                        <select class="select" name="subscriptionIsActive">
                            <option value="">Subscription Status</option>
                            <option value="true" <%= filters?.subscriptionIsActive === "true" ? "selected" : "" %>>Active</option>
                            <option value="false" <%= filters?.subscriptionIsActive === "false" ? "selected" : "" %>>Inactive</option>
                        </select>
                    </div>

                    <button type="submit" class="main__button button__text btn">Apply Filters</button>
                </form>
            </article>

            <br>

            <article class="admin__panel">
                <header class="admin__panel-header">
                    <div>
                        <p class="admin__eyebrow">Users Table</p>
                        <h2><%= title ?? "Users" %></h2>
                    </div>
                </header>

                <% if (users?.length) { %>
                    <div class="table-wrapper">
                        <table class="table">
                            <thead class="table__header">
                                <tr class="table__row">
                                    <th class="table__cell">Username</th>
                                    <th class="table__cell">Email</th>
                                    <th class="table__cell">Phone</th>
                                    <th class="table__cell">Role</th>
                                    <th class="table__cell">Plan</th>
                                    <th class="table__cell">Active Subscriptions</th>
                                    <th class="table__cell">Actions</th>
                                </tr>
                            </thead>

                            <tbody class="table__body">
                                <% users.forEach((item) => { %>
                                    <tr class="table__row">
                                        <td class="table__cell"><%= item?.username ?? "N/A" %></td>
                                        <td class="table__cell"><%= item?.email ?? "N/A" %></td>
                                        <td class="table__cell"><%= item?.phoneNumber ?? "N/A" %></td>
                                        <td class="table__cell"><span class="badge info__badge"><%= item?.role ?? "user" %></span></td>
                                        <td class="table__cell"><%= item?.subscription?.plan ?? "free" %></td>
                                        <td class="table__cell"><%= item?.subscription?.isActive ? "Yes" : "No" %></td>
                                        <td class="table__cell table__actions">
                                            <a href="/admin/users/<%= item?.id ?? item?._id %>" class="btn button__sm info__button">View</a>

                                            <% if (item?.isDeleted) { %>
                                                <form action="/admin/users/<%= item?.id ?? item?._id %>/restore" method="POST" style="display:inline;">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <button class="btn button__sm success__button" type="submit">Restore</button>
                                                </form>
                                            <% } else { %>
                                                <form action="/admin/users/<%= item?.id ?? item?._id %>/delete" method="POST" style="display:inline;">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <button class="btn button__sm error__button" type="submit">Delete</button>
                                                </form>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="alert info__alert">No users found.</div>
                <% } %>
            </article>
        </div>
    </section>
</main>

<%- include("../../partials/admin_footer") %>